# Copied to .env for local dev. Vite only exposes variables prefixed with VITE_.

# API base (must include /api — same as Nest global prefix).
# Local: /api is proxied to http://localhost:4000 (see vite.config.js).
VITE_API_BASE_URL=/api

# Production build example (set in host UI or .env.production):
# VITE_API_BASE_URL=https://your-api.up.railway.app/api
#
# Optional override for `/uploads/...` URLs only — full prefix including /api, e.g. https://your-api.up.railway.app/api
# VITE_UPLOADS_ORIGIN=https://your-api.up.railway.app/api
