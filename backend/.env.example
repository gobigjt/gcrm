PORT=4000
DATABASE_URL=postgresql://postgres:password@localhost:5432/EzCRM
# Full public URL of this API including the global prefix (no trailing slash). Used when rendering PDFs so
# headless Chrome can load `/uploads/...` images (same value as the frontend’s VITE_API_BASE_URL in production).
# Local: http://127.0.0.1:4000/api
# API_PUBLIC_URL=http://127.0.0.1:4000/api
#
# Files live under ./uploads (invoice logos, user avatars, product images). On Railway/Docker/etc. the
# disk is often wiped on each deploy unless you attach a persistent volume at this path (or use S3).
JWT_SECRET=change_this_secret_key
# Access JWT lifetime: use a span (1d, 12h, 15m) OR an integer = seconds (86400 = 1 day).
# Plain "86400" from env must be parsed as seconds in code; otherwise jsonwebtoken/ms treats it as milliseconds (~86s).
JWT_EXPIRES_IN=1d
# Optional: public web app origin for CRM notification deep links (no trailing slash). If unset, links stay path-only (/crm?lead=…).
# WEB_APP_ORIGIN=https://crm.example.com
# FCM service account credentials (set either JSON string OR path to JSON file)
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# FCM_SERVICE_ACCOUNT_PATH=./secrets/firebase-service-account.json

# Facebook Lead Ads — Settings → Lead Platforms → “Continue with Facebook” (Facebook Login).
# Create an app at https://developers.facebook.com — add “Facebook Login”, set Valid OAuth Redirect URIs to your CRM web origin (e.g. http://localhost:5173).
# In Facebook Login → Settings, allow permissions: pages_show_list, pages_read_engagement, leads_retrieval (App Review if the app is Live).
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# Optional Graph version (default v20.0)
# FACEBOOK_GRAPH_API_VERSION=v20.0
# Webhook verify token — choose any string; set the same value in Meta App Dashboard → Webhooks → Verify Token
# FACEBOOK_WEBHOOK_TOKEN=
