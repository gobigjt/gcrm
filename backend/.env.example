PORT=4000
DATABASE_URL=postgresql://postgres:password@localhost:5432/EzCRM
JWT_SECRET=change_this_secret_key
# Access JWT lifetime: use a span (1d, 12h, 15m) OR an integer = seconds (86400 = 1 day).
# Plain "86400" from env must be parsed as seconds in code; otherwise jsonwebtoken/ms treats it as milliseconds (~86s).
JWT_EXPIRES_IN=1d
# Optional: public web app origin for CRM notification deep links (no trailing slash). If unset, links stay path-only (/crm?lead=…).
# WEB_APP_ORIGIN=https://crm.example.com
